# Git Settings

# Auto detect text files and normalize line endings
* text=auto

# Force LF for all text files (consistent across OS)
* text=auto eol=lf

# Language Detection (GitHub Linguist)

# SQL
*.sql linguist-detectable=true
*.sql linguist-language=sql

# YAML
*.yaml linguist-detectable=true
*.yaml linguist-language=yaml
*.yml linguist-detectable=true
*.yml linguist-language=yaml

# Shell / Bash
*.sh linguist-detectable=true
*.sh linguist-language=shell
*.bash linguist-detectable=true
*.bash linguist-language=shell

# Dockerfile
Dockerfile linguist-detectable=true
Dockerfile linguist-language=dockerfile
Dockerfile.* linguist-detectable=true
Dockerfile.* linguist-language=dockerfile

# Makefile
Makefile linguist-detectable=true
Makefile linguist-language=makefile

# JSON
*.json linguist-detectable=true
*.json linguist-language=json

# TOML
*.toml linguist-detectable=true
*.toml linguist-language=toml

# Markdown
*.md linguist-detectable=true
*.md linguist-language=markdown

# HCL / Terraform
*.tf linguist-detectable=true
*.tf linguist-language=hcl
*.tfvars linguist-detectable=true
*.tfvars linguist-language=hcl

# Kubernetes / Helm (YAML already covered above)
# No extra config needed if *.yaml is set

# Nginx config
*.conf linguist-detectable=true
*.conf linguist-language=nginx

# INI / Config files
*.ini linguist-detectable=true
*.ini linguist-language=ini
*.cfg linguist-detectable=true
*.cfg linguist-language=ini
*.env linguist-detectable=true
*.env linguist-language=shell

# =============================================================
# Binary Files (prevent line ending changes)
# =============================================================

*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.svg binary
*.pdf binary
*.zip binary
*.tar binary
*.gz binary
*.jar binary
*.war binary
*.class binary

# =============================================================
# Exclude from GitHub language stats (vendor/generated/docs)
# =============================================================

# Node modules
node_modules/* linguist-vendored

# Build output
dist/* linguist-generated
build/* linguist-generated
out/* linguist-generated

# Lock files (don't skew language stats)
package-lock.json linguist-generated
yarn.lock linguist-generated
pnpm-lock.yaml linguist-generated
Cargo.lock linguist-generated

# Docs
docs/* linguist-documentation
*.md linguist-documentation=false
README.md linguist-documentation=false
